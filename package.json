{
  "name": "deloc",
  "private": true,
  "description": "Open-source CLI and MCP for Deloc — deploy static apps from your terminal or AI coding agent",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/delocdev/deloc"
  },
  "license": "MIT"
}
